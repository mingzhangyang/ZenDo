{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "zendo",
  "main": "worker.js",
  "compatibility_date": "2026-04-16",
  "workers_dev": false,
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
    "not_found_handling": "single-page-application"
  },
  "ai": {
    "binding": "AI"
  },
  "vars": {
    "AI_MODEL": "@cf/zai-org/glm-4.7-flash"
  }
}
